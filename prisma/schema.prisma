generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── TENANT (Torneo) ─────────────────────────────
model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  createdAt DateTime @default(now())

  // Configuración del torneo
  startDate     DateTime?
  matchDays     String[]
  matchesPerDay Int       @default(2)
  matchDuration Int       @default(90)
  roundTrip     Boolean   @default(false)

  // Flyer / Landing
  description   String?
  endDate       DateTime?
  maxTeams      Int?
  inscriptionFee Float?
  contactName   String?
  contactPhone  String?
  contactEmail  String?
  instagram     String?
  facebook      String?
  whatsapp      String?
  bannerUrl     String?
  published     Boolean  @default(false)

  teams     Team[]
  matches   Match[]
  rounds    Round[]
  referees  Referee[]
  users     TenantUser[]
  finances  Finance[]
}

// ─── USUARIOS ────────────────────────────────────
model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String?
  password     String?
  isSuperAdmin Boolean      @default(false)  // ← agregar esto
  tenants      TenantUser[]
}

model TenantUser {
  id       String   @id @default(cuid())
  role     Role     @default(VIEWER)
  user     User     @relation(fields: [userId], references: [id])
  userId   String
  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  tenantId String

  @@unique([userId, tenantId])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  VIEWER
}

// ─── EQUIPOS Y JUGADORES ─────────────────────────
model Team {
  id       String  @id @default(cuid())
  name     String
  logo     String?
  phone    String?   // ← WhatsApp del capitán
  captain  String?   // ← Nombre del capitán
  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  tenantId String

  players     Player[]
  homeMatches Match[]   @relation("HomeTeam")
  awayMatches Match[]   @relation("AwayTeam")
  finances    Finance[]
}

model Player {
  id       String  @id @default(cuid())
  name     String
  number   Int?
  position String?
  photo    String?
  team     Team    @relation(fields: [teamId], references: [id])
  teamId   String

  stats PlayerStat[]
}

// ─── JORNADAS ────────────────────────────────────
model Round {
  id       String  @id @default(cuid())
  number   Int
  name     String?
  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  tenantId String

  matches Match[]

  @@unique([tenantId, number])
}

// ─── PARTIDOS ────────────────────────────────────
model Match {
  id         String      @id @default(cuid())
  date       DateTime
  cancha     Int?  
  homeScore  Int?
  awayScore  Int?
  status     MatchStatus @default(SCHEDULED)
  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  tenantId   String
  homeTeam   Team        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  homeTeamId String
  awayTeam   Team        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  awayTeamId String
  referee    Referee?    @relation(fields: [refereeId], references: [id])
  refereeId  String?
  round      Round?      @relation(fields: [roundId], references: [id])
  roundId    String?

  events MatchEvent[]
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  CANCELLED
}

model MatchEvent {
  id       String    @id @default(cuid())
  type     EventType
  minute   Int
  match    Match     @relation(fields: [matchId], references: [id])
  matchId  String
  player   PlayerStat @relation(fields: [playerId], references: [id])
  playerId String
}

enum EventType {
  GOAL
  YELLOW_CARD
  RED_CARD
  SUBSTITUTION
}

// ─── ESTADÍSTICAS ────────────────────────────────
model PlayerStat {
  id       String @id @default(cuid())
  goals    Int    @default(0)
  assists  Int    @default(0)
  yellow   Int    @default(0)
  red      Int    @default(0)
  player   Player @relation(fields: [playerId], references: [id])
  playerId String @unique

  events MatchEvent[]
}

// ─── ÁRBITROS ────────────────────────────────────
model Referee {
  id          String   @id @default(cuid())
  name        String
  phone       String?
  email       String?
  payPerMatch Float    @default(0)
  notes       String?
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  tenantId    String

  matches Match[]
}

// ─── FINANZAS ────────────────────────────────────
model Finance {
  id          String          @id @default(cuid())
  type        FinanceType
  category    FinanceCategory @default(OTRO)
  amount      Float
  description String?
  date        DateTime        @default(now())
  team        Team?           @relation(fields: [teamId], references: [id])
  teamId      String?
  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  tenantId    String
}
enum FinanceType {
  INCOME
  EXPENSE
}

enum FinanceCategory {
  CUOTA_EQUIPO
  PAGO_ARBITRO
  GASTO_CANCHA
  GASTO_TROFEOS
  GASTO_GENERAL
  PREMIO
  OTRO
}